<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Edit Blog - Blogify</title>
</head>
<body>
    <%- include("partials/nav") %>

    <main class="container page-shell">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="mb-4">
                    <p class="author-chip mb-3"><i class="bi bi-pencil-square"></i> Edit post</p>
                    <h1 class="page-title mb-2">Update your post.</h1>
                    <p class="muted-copy">Only the owner of this blog can edit this content.</p>
                </div>

                <div class="card">
                    <div class="card-body p-4 p-lg-5">
                        <form action="/blog/<%= blog._id %>/edit" method="post" enctype="multipart/form-data">
                            <div class="mb-4">
                                <label for="title" class="form-label">Title</label>
                                <input type="text" class="form-control" id="title" name="title" value="<%= blog.title %>" required>
                            </div>

                            <% if (blog.coverImageURL) { %>
                                <img src="<%= blog.coverImageURL %>" class="blog-cover-img mb-3" alt="<%= blog.title %>">
                            <% } %>

                            <div class="mb-4">
                                <label for="coverImage" class="form-label">Replace Cover Image</label>
                                <input type="file" class="form-control" id="coverImage" name="coverImage" accept="image/*">
                            </div>

                            <div class="mb-4">
                                <label for="body" class="form-label">Content</label>
                                <textarea class="form-control" id="body" name="body" rows="12" required><%= blog.body %></textarea>
                            </div>

                            <div class="d-flex flex-wrap justify-content-between gap-2">
                                <a href="/blog/<%= blog._id %>" class="btn btn-outline-secondary">Cancel</a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save"></i> Save Changes
                                </button>
                            </div>
                        </form>

                        <form action="/blog/<%= blog._id %>/delete" method="post" class="mt-3" onsubmit="return confirm('Delete this post permanently?');">
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete Post
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('./partials/scripts') %>
</body>
</html>
