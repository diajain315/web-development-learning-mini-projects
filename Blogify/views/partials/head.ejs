<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
    crossorigin="anonymous">

<link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    body {
        background: #f7f5f0;
        color: #202124;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        min-height: 100vh;
    }

    a {
        color: #365c4f;
    }

    .navbar-custom {
        background: rgba(255, 255, 255, 0.94);
        border-bottom: 1px solid #e7e1d8;
        backdrop-filter: blur(14px);
        padding: 12px 0;
        position: sticky;
        top: 0;
        z-index: 20;
    }

    .navbar-custom .navbar-brand {
        color: #202124;
        font-size: 1.25rem;
        font-weight: 800;
    }

    .navbar-custom .nav-link {
        color: #555b57 !important;
        border-radius: 8px;
        font-weight: 600;
        padding: 8px 12px;
    }

    .navbar-custom .nav-link:hover,
    .navbar-custom .nav-link.active {
        background: #eef3ec;
        color: #1f4d3b !important;
    }

    .navbar-toggler {
        border: 0;
        box-shadow: none !important;
    }

    .profile-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #d8d1c6;
    }

    .page-shell {
        padding: 38px 0 56px;
    }

    .page-title {
        font-size: clamp(2rem, 4vw, 3.6rem);
        font-weight: 800;
        letter-spacing: 0;
        line-height: 1.05;
    }

    .muted-copy {
        color: #6f736f;
    }

    .card,
    .soft-panel,
    .card-blog {
        background: #fffdf8;
        border: 1px solid #e7e1d8;
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(31, 36, 33, 0.05);
    }

    .card-blog {
        height: 100%;
        overflow: hidden;
        transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .card-blog:hover {
        transform: translateY(-3px);
        box-shadow: 0 16px 40px rgba(31, 36, 33, 0.08);
    }

    .card-blog .card-img-top {
        aspect-ratio: 16 / 10;
        height: auto;
        object-fit: cover;
        width: 100%;
    }

    .card-title,
    .section-title {
        color: #202124;
        font-weight: 800;
    }

    .btn {
        border-radius: 8px;
        font-weight: 700;
    }

    .btn-primary {
        background: #2f604f;
        border-color: #2f604f;
    }

    .btn-primary:hover {
        background: #23483b;
        border-color: #23483b;
    }

    .btn-outline-primary {
        border-color: #2f604f;
        color: #2f604f;
    }

    .btn-outline-primary:hover {
        background: #2f604f;
        border-color: #2f604f;
        color: #fff;
    }

    .btn-outline-danger,
    .btn-outline-secondary {
        border-radius: 8px;
    }

    .form-control {
        background: #fffefb;
        border: 1px solid #d9d3c9;
        border-radius: 8px;
        padding: 12px 14px;
    }

    .form-control:focus {
        border-color: #2f604f;
        box-shadow: 0 0 0 4px rgba(47, 96, 79, 0.12);
    }

    .form-label {
        color: #303530;
        font-weight: 700;
    }

    .blog-header {
        border-bottom: 1px solid #e7e1d8;
        padding: 26px 0 18px;
    }

    .blog-cover-img {
        aspect-ratio: 16 / 8;
        border-radius: 8px;
        object-fit: cover;
        width: 100%;
    }

    .blog-body {
        color: #272b28;
        font-size: 1.06rem;
        line-height: 1.85;
        white-space: pre-line;
    }

    .author-chip {
        background: #eef3ec;
        border: 1px solid #dbe6d8;
        border-radius: 999px;
        color: #315044;
        display: inline-flex;
        font-size: 0.9rem;
        font-weight: 700;
        gap: 8px;
        padding: 6px 10px;
    }

    .manage-bar {
        align-items: center;
        background: #f3f7f1;
        border: 1px solid #dbe6d8;
        border-radius: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: space-between;
        margin-bottom: 24px;
        padding: 14px;
    }

    .owner-actions {
        background: #f3f7f1;
        border: 1px solid #dbe6d8;
        border-radius: 8px;
        padding: 10px;
    }

    .profile-hero {
        align-items: center;
        display: flex;
        gap: 18px;
    }

    .profile-hero img {
        border-radius: 50%;
        height: 84px;
        object-fit: cover;
        width: 84px;
    }

    .comment-row:last-child {
        border-bottom: 0 !important;
    }

    @media (max-width: 576px) {
        .profile-hero {
            align-items: flex-start;
            flex-direction: column;
        }

        .blog-cover-img {
            aspect-ratio: 4 / 3;
        }
    }
</style>
