<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Add New Blog - Blogify</title>
</head>
<body>
    <%- include("partials/nav") %>

    <main class="container page-shell">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="mb-4">
                    <p class="author-chip mb-3"><i class="bi bi-pencil"></i> New post</p>
                    <h1 class="page-title mb-2">Write something clear.</h1>
                    <p class="muted-copy">Add a title, optional cover image, and your post content.</p>
                </div>

                <div class="card">
                    <div class="card-body p-4 p-lg-5">
                        <form action="/blog" method="post" enctype="multipart/form-data">
                            <div class="mb-4">
                                <label for="title" class="form-label">Title</label>
                                <input type="text" class="form-control" id="title" name="title" placeholder="Post title" required>
                            </div>

                            <div class="mb-4">
                                <label for="coverImage" class="form-label">Cover Image</label>
                                <input type="file" class="form-control" id="coverImage" name="coverImage" accept="image/*">
                            </div>

                            <div class="mb-4">
                                <label for="body" class="form-label">Content</label>
                                <textarea class="form-control" id="body" name="body" rows="12" placeholder="Start writing..." required></textarea>
                            </div>

                            <div class="d-flex justify-content-end gap-2">
                                <a href="/" class="btn btn-outline-secondary">Cancel</a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i> Publish
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('./partials/scripts') %>
</body>
</html>
