<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>My Profile - Blogify</title>
</head>
<body>
    <%- include("partials/nav") %>

    <main class="container page-shell">
        <section class="row g-4 mb-4">
            <div class="col-lg-5">
                <div class="soft-panel p-4">
                    <div class="profile-hero mb-4">
                        <img src="<%= user.profileImageURL || '/images/default.png' %>" alt="<%= user.fullName %>">
                        <div>
                            <h1 class="h3 section-title mb-1"><%= user.fullName %></h1>
                            <p class="muted-copy mb-1"><%= user.email %></p>
                            <span class="author-chip"><i class="bi bi-shield-check"></i> <%= user.role %></span>
                        </div>
                    </div>

                    <form action="/user/profile" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="fullName" class="form-label">Display Name</label>
                            <input type="text" class="form-control" id="fullName" name="fullName" value="<%= user.fullName %>" required>
                        </div>
                        <div class="mb-4">
                            <label for="profileImage" class="form-label">Profile Image</label>
                            <input type="file" class="form-control" id="profileImage" name="profileImage" accept="image/*">
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save Profile
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <p class="author-chip mb-2"><i class="bi bi-collection"></i> Your posts</p>
                        <h2 class="section-title h3 mb-0"><%= blogs.length %> published</h2>
                    </div>
                    <a href="/blog/add-new" class="btn btn-primary"><i class="bi bi-plus-circle"></i> New Post</a>
                </div>

                <% if (blogs.length > 0) { %>
                    <div class="row g-3">
                        <% blogs.forEach(blog => { %>
                            <div class="col-12">
                                <article class="card">
                                    <div class="card-body d-flex flex-column flex-md-row gap-3">
                                        <img src="<%= blog.coverImageURL || '/images/default.png' %>" alt="<%= blog.title %>" style="width: 150px; aspect-ratio: 16 / 10; object-fit: cover; border-radius: 8px;">
                                        <div class="flex-grow-1">
                                            <small class="muted-copy"><%= new Date(blog.createdAt).toLocaleDateString() %></small>
                                            <h3 class="h5 section-title mt-1"><%= blog.title %></h3>
                                            <p class="muted-copy mb-3"><%= blog.body.substring(0, 120) %><%= blog.body.length > 120 ? '...' : '' %></p>
                                            <div class="d-flex flex-wrap gap-2">
                                                <a href="/blog/<%= blog._id %>" class="btn btn-primary btn-sm">Open</a>
                                                <a href="/blog/<%= blog._id %>/edit" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil"></i> Edit</a>
                                                <form action="/blog/<%= blog._id %>/delete" method="post" onsubmit="return confirm('Delete this post permanently?');">
                                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="soft-panel text-center p-5">
                        <i class="bi bi-journal-plus display-5 muted-copy"></i>
                        <h3 class="h5 section-title mt-3">No posts from you yet</h3>
                        <p class="muted-copy">Create a post and manage it from this page.</p>
                    </div>
                <% } %>
            </div>
        </section>
    </main>

    <%- include('./partials/scripts') %>
</body>
</html>
