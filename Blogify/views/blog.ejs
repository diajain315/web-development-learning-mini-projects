<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title><%= blog.title %> - Blogify</title>
</head>
<body>
    <%- include("partials/nav") %>

    <% const canManage = locals.user && String(blog.createdBy._id) === String(locals.user._id); %>

    <main class="container page-shell">
        <article>
            <header class="blog-header mb-4">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                    <div>
                        <p class="author-chip mb-3">
                            <img src="<%= blog.createdBy.profileImageURL || '/images/default.png' %>" width="22" height="22" class="rounded-circle" alt="">
                            <%= blog.createdBy.fullName %>
                        </p>
                        <h1 class="page-title mb-3"><%= blog.title %></h1>
                        <p class="muted-copy mb-0">
                            <i class="bi bi-calendar3"></i>
                            <%= new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                        </p>
                    </div>

                    <% if (canManage) { %>
                        <div class="d-flex gap-2">
                            <a href="/blog/<%= blog._id %>/edit" class="btn btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form action="/blog/<%= blog._id %>/delete" method="post" onsubmit="return confirm('Delete this post permanently?');">
                                <button type="submit" class="btn btn-outline-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    <% } %>
                </div>
            </header>

            <% if (blog.coverImageURL) { %>
                <img src="<%= blog.coverImageURL %>" class="blog-cover-img mb-4" alt="<%= blog.title %>">
            <% } %>

            <div class="card mb-4">
                <div class="card-body p-4 p-lg-5">
                    <% if (canManage) { %>
                        <div class="manage-bar">
                            <div>
                                <strong><i class="bi bi-sliders"></i> Manage this post</strong>
                                <div class="muted-copy small">You can edit or delete this blog because you are the owner.</div>
                            </div>
                            <div class="d-flex gap-2">
                                <a href="/blog/<%= blog._id %>/edit" class="btn btn-primary">
                                    <i class="bi bi-pencil"></i> Edit Blog
                                </a>
                                <form action="/blog/<%= blog._id %>/delete" method="post" onsubmit="return confirm('Delete this post permanently?');">
                                    <button type="submit" class="btn btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete Blog
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% } %>
                    <div class="blog-body">
                        <%= blog.body %>
                    </div>
                </div>
            </div>
        </article>

        <section class="soft-panel p-4 mb-4">
            <div class="d-flex align-items-center gap-3">
                <img src="<%= blog.createdBy.profileImageURL || '/images/default.png' %>" width="62" height="62" class="rounded-circle" style="object-fit: cover;" alt="<%= blog.createdBy.fullName %>">
                <div>
                    <h2 class="h5 section-title mb-1"><%= blog.createdBy.fullName %></h2>
                    <p class="muted-copy mb-0"><i class="bi bi-envelope"></i> <%= blog.createdBy.email %></p>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-body p-4 p-lg-5">
                <h2 class="section-title h4 mb-4">
                    <i class="bi bi-chat-dots"></i> Comments (<%= comments ? comments.length : 0 %>)
                </h2>

                <% if (locals.user) { %>
                    <form action="/blog/comment/<%= blog._id %>" method="POST" class="mb-4">
                        <div class="d-flex gap-2">
                            <input type="text" name="content" class="form-control" placeholder="Write a comment..." required>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i> Post
                            </button>
                        </div>
                    </form>
                <% } else { %>
                    <div class="alert alert-info">
                        <a href="/user/signin" class="fw-bold">Sign in</a> to leave a comment.
                    </div>
                <% } %>

                <% if (comments && comments.length > 0) { %>
                    <% comments.forEach(comment => { %>
                        <div class="comment-row d-flex gap-3 py-3 border-bottom">
                            <img src="<%= comment.createdBy.profileImageURL || '/images/default.png' %>" width="42" height="42" class="rounded-circle flex-shrink-0" style="object-fit: cover;" alt="<%= comment.createdBy.fullName %>">
                            <div>
                                <h3 class="h6 section-title mb-1">
                                    <%= comment.createdBy.fullName %>
                                    <small class="muted-copy fw-normal ms-2"><%= new Date(comment.createdAt).toLocaleDateString() %></small>
                                </h3>
                                <p class="mb-0"><%= comment.content %></p>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="muted-copy mb-0">No comments yet. Start the conversation.</p>
                <% } %>
            </div>
        </section>

        <div class="mt-4">
            <a href="/" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left"></i> Back Home
            </a>
        </div>
    </main>

    <%- include('./partials/scripts') %>
</body>
</html>
